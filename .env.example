# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings + GPT-4o fallback)
OPENAI_API_KEY=sk-...

# LangSmith
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=systematic-compliance-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=compliance_agent
POSTGRES_USER=compliance
POSTGRES_PASSWORD=compliance_secret

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_COMPLAINTS_TOPIC=raw-complaints
KAFKA_DLQ_TOPIC=complaints-dlq

# ChromaDB — "local" uses PersistentClient (no Docker), "server" uses HttpClient (Docker)
CHROMA_MODE=local
CHROMA_LOCAL_PATH=./chroma_data
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_COMPLAINTS=cfpb_complaints
CHROMA_COLLECTION_REGULATORY=regulatory_corpus

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=compliance-classifier

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
CONFIDENCE_THRESHOLD=0.72
REGULATORY_REVIEW_PASS_SCORE=80
MAX_TOKENS_PER_COMPLAINT=512

# Mock integrations
JIRA_BASE_URL=http://localhost:9090/jira
JIRA_PROJECT_KEY=COMPLIANCE
MOCK_EXTERNAL_APIS=true
