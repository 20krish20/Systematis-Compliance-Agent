{
  "id": null,
  "title": "Systematic Compliance Agent - Pipeline Health",
  "tags": ["compliance", "fintech", "ai"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Complaints Processed / Hour",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(compliance_agent_complaints_processed_total[1h]) * 3600",
          "legendFormat": "Throughput (hr)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 500},
              {"color": "green", "value": 1000}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Human Escalation Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "compliance_agent_escalation_rate",
          "legendFormat": "Escalation Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.08},
              {"color": "red", "value": 0.12}
            ]
          },
          "unit": "percentunit",
          "max": 1
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
    },
    {
      "id": 3,
      "title": "Pipeline Duration P95",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(compliance_agent_pipeline_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 Duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 15},
              {"color": "red", "value": 30}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
    },
    {
      "id": 4,
      "title": "Avg Regulatory Review Score",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(compliance_agent_regulatory_review_score_bucket[10m]))",
          "legendFormat": "Median Score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 75},
              {"color": "green", "value": 85}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
    },
    {
      "id": 5,
      "title": "Complaints Processed Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(compliance_agent_complaints_processed_total[5m]) * 60",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    },
    {
      "id": 6,
      "title": "Agent Error Rates",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(compliance_agent_agent_errors_total[5m])",
          "legendFormat": "{{agent_name}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    },
    {
      "id": 7,
      "title": "Classification Confidence Distribution",
      "type": "histogram",
      "targets": [
        {
          "expr": "rate(compliance_agent_classification_confidence_bucket[10m])",
          "legendFormat": "{{dimension}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12}
    },
    {
      "id": 8,
      "title": "LLM Token Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(compliance_agent_llm_tokens_total[5m])",
          "legendFormat": "{{model}} {{direction}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12}
    },
    {
      "id": 9,
      "title": "Disparate Impact Flags",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(compliance_agent_disparate_impact_flags_total[10m])",
          "legendFormat": "Fairness Violations/min"
        }
      ],
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 20}
    },
    {
      "id": 10,
      "title": "Gini Index (Fairness)",
      "type": "stat",
      "targets": [
        {
          "expr": "compliance_agent_gini_index",
          "legendFormat": "Gini"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.03},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      },
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 20}
    }
  ]
}
